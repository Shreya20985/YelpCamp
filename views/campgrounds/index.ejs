<%layout('layouts/boilerplate') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>All Campgrounds</h1>
    <a href="/campgrounds/new" class="btn btn-success">Add Campground</a>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% for(let campground of campgrounds){ %>
        <div class="col">
            <div class="card h-100 shadow-sm">
                <img class="card-img-top" style="height: 220px; object-fit: cover;"
                    src="<%= campground.images.length ? campground.images[0].url : 'https://res.cloudinary.com/dfxnix4zz/image/upload/v1774701195/YelpCamp/dhgqgwl4gyrsiibzw5e8.jpg' %>">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><%=campground.title%></h5>
                    <p class="card-text text-truncate"><%=campground.description%></p>
                    <p class="card-text">
                        <small class="text-muted"><%=campground.location %></small>
                    </p>
                    <a class="btn btn-primary mt-auto" href="/campgrounds/<%=campground._id%>">View <%=campground.title%></a>
                </div>
            </div>
        </div>
    <% } %>
</div>