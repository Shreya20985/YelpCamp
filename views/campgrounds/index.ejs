<%layout('layouts/boilerplate') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>All Campgrounds</h1>
    <a href="/campgrounds/new" class="btn btn-success">Add Campground</a>
</div>

<% if(campgrounds.length === 0){ %>
    <div class="text-center text-muted py-5">
        <h4>No campgrounds yet</h4>
        <p>Be the first to add one!</p>
        <a href="/campgrounds/new" class="btn btn-success">Add Campground</a>
    </div>
<% } else { %>
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% for(let campground of campgrounds){ %>
        <div class="col">
            <div class="card h-100 shadow-sm campground-card">
                <img class="card-img-top" style="height: 220px; object-fit: cover;"
                    src="<%= campground.images.length ? campground.images[0].url : 'https://res.cloudinary.com/dfxnix4zz/image/upload/v1774701195/YelpCamp/dhgqgwl4gyrsiibzw5e8.jpg' %>">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="card-title mb-1"><%=campground.title%></h5>
                        <span class="badge bg-success">₹<%=campground.price%>/night</span>
                    </div>
                    <p class="card-text text-truncate text-muted small mt-2"><%=campground.description%></p>
                    <p class="card-text">
                        <small class="text-muted">📍 <%=campground.location %></small>
                    </p>
                    <a class="btn btn-primary mt-auto" href="/campgrounds/<%=campground._id%>">View <%=campground.title%></a>
                </div>
            </div>
        </div>
    <% } %>
</div>
<% } %>

<style>
.campground-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.campground-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.15) !important;
}
</style>